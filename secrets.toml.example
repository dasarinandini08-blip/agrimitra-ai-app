# Copy this file to ".streamlit/secrets.toml" and fill in real values.
# Streamlit will auto-load this file; access keys in code via st.secrets["KEY_NAME"]
# This example file is safe to commit; the real secrets.toml is gitignored.

OPENAI_API_KEY = "your_openai_api_key_here"
GOOGLE_API_KEY = "your_google_gemini_api_key_here"
OPENWEATHER_API_KEY = "your_openweathermap_api_key_here"
MANDI_API_KEY = "your_mandi_api_key_here"
