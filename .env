# Copy this file to ".env" and fill in your real keys.
# NEVER commit your actual .env file to git (it's already in .gitignore below).

# LLM Provider Keys (pick whichever you use in generate_farming_advice)
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_gemini_api_key_here
ANTHROPIC_API_KEY=sk-ypur_anthropic_api_key_here

# Weather API (e.g. OpenWeatherMap)
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Mandi / Market Price API (e.g. data.gov.in Agmarknet)
MANDI_API_KEY=your_mandi_api_key_here
